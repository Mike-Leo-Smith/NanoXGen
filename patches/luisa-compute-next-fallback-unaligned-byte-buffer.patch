@@ -19,5 +19,6 @@
 #include <luisa/runtime/device.h>
 #include <luisa/runtime/stream.h>
 #include <luisa/runtime/event.h>
+#include <luisa/runtime/bindless_array.h>
 #include <luisa/dsl/sugar.h>
 #include <luisa/runtime/byte_buffer.h>
@@ -25,3 +26,7 @@
+#include <array>
+#include <cstddef>
+#include <cstring>
+
 using namespace luisa;
 using namespace luisa::compute;
 using namespace boost::ut;
@@ -108,3 +113,40 @@
+void test_unaligned_byte_buffer_vector_io(Device &device) {
+    auto input = device.create_byte_buffer(32u);
+    auto output = device.create_byte_buffer(32u);
+    auto bindless = device.create_bindless_array(1u);
+    std::array<std::byte, 32u> source{};
+    const std::array<float, 3u> expected{1.25f, -2.5f, 3.75f};
+    std::memcpy(source.data() + 3u, expected.data(), sizeof(expected));
+
+    auto shader = device.compile<1>(
+        [](ByteBufferVar src, ByteBufferVar dst,
+           BindlessVar heap) noexcept {
+            const Float3 value = src.read<float3>(3u);
+            dst.write(5u, value);
+            dst.write(
+                17u, heap.byte_buffer(0u).read<float3>(3u));
+        });
+    std::array<std::byte, 32u> result{};
+    auto stream = device.create_stream();
+    stream << input.copy_from(source.data())
+           << bindless.emplace_on_update(0u, input)
+                  .update()
+           << shader(input, output, bindless).dispatch(1u)
+           << output.copy_to(result.data())
+           << synchronize();
+
+    auto all_correct = true;
+    for (const auto offset : {5u, 17u}) {
+        std::array<float, 3u> actual{};
+        std::memcpy(actual.data(), result.data() + offset, sizeof(actual));
+        for (auto i = 0u; i < actual.size(); ++i) {
+            all_correct &= actual[i] == expected[i];
+        }
+    }
+    expect(all_correct)
+        << "unaligned direct/bindless ByteBuffer vector I/O";
+}
+
 int main(int argc, char *argv[]) {
     auto dc = luisa::test::create_device_from_ut(argc, argv);
     if (!dc) {
@@ -116,4 +158,5 @@ int main(int argc, char *argv[]) {
     test_byte_buffer(device);
     test_byte_buffer_bool_read(device);
     test_byte_buffer_volatile_io(device);
+    test_unaligned_byte_buffer_vector_io(device);
 }
