{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 20,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "NANOXGEN_BUILD_TESTS": "ON",
        "NANOXGEN_BUILD_CALIBRATION": "OFF"
      }
    },
    {
      "name": "release",
      "displayName": "Release",
      "description": "Portable optimized CPU build with tests",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "NANOXGEN_ENABLE_CUDA": "OFF",
        "NANOXGEN_ENABLE_HIP": "OFF"
      }
    },
    {
      "name": "debug",
      "displayName": "Debug",
      "description": "Debug CPU build with tests",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "NANOXGEN_ENABLE_CUDA": "OFF"
      }
    },
    {
      "name": "native-release",
      "displayName": "Native release",
      "description": "Host-tuned LTO build for local benchmarking",
      "inherits": "release",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "NANOXGEN_ENABLE_IPO": "ON",
        "NANOXGEN_NATIVE_ARCH": "ON",
        "NANOXGEN_SIMD_WIDTH": "256"
      }
    },
    {
      "name": "cuda-release",
      "displayName": "CUDA release",
      "description": "Release build of all CPU and CUDA targets",
      "inherits": "release",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "NANOXGEN_ENABLE_CUDA": "ON"
      }
    },
    {
      "name": "hip-release",
      "displayName": "HIP release",
      "description": "Release build of all CPU and AMD HIP targets",
      "inherits": "release",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "NANOXGEN_ENABLE_HIP": "ON"
      }
    },
    {
      "name": "luisa-hip-release",
      "displayName": "LuisaCompute next HIP release",
      "description": "Release build with an external LuisaCompute next HIP runtime",
      "inherits": "release",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "NANOXGEN_ENABLE_HIP": "ON",
        "NANOXGEN_ENABLE_LUISA": "ON",
        "NANOXGEN_LUISA_BACKEND": "hip",
        "LUISA_COMPUTE_SOURCE_DIR": "$env{LUISA_COMPUTE_SOURCE_DIR}",
        "LUISA_COMPUTE_BUILD_DIR": "$env{LUISA_COMPUTE_BUILD_DIR}"
      }
    },
    {
      "name": "classic-alembic-release",
      "displayName": "Classic Alembic import release",
      "description": "Release build with the optional system Alembic patch importer",
      "inherits": "release",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "NANOXGEN_ENABLE_ALEMBIC": "ON"
      }
    },
    {
      "name": "calibration-release",
      "displayName": "XGen calibration release",
      "description": "Optional Autodesk-backed oracle and conversion tools",
      "inherits": "release",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "NANOXGEN_BUILD_CALIBRATION": "ON"
      }
    },
    {
      "name": "autodesk-bridge-release",
      "displayName": "Autodesk bridge release",
      "description": "Optional Classic and Interactive Autodesk renderer bridges",
      "inherits": "release",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "NANOXGEN_BUILD_AUTODESK_BRIDGES": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "release",
      "configurePreset": "release",
      "jobs": 2
    },
    {
      "name": "debug",
      "configurePreset": "debug",
      "jobs": 2
    },
    {
      "name": "native-release",
      "configurePreset": "native-release",
      "jobs": 2
    },
    {
      "name": "cuda-release",
      "configurePreset": "cuda-release",
      "jobs": 2
    },
    {
      "name": "hip-release",
      "configurePreset": "hip-release",
      "jobs": 2
    },
    {
      "name": "luisa-hip-release",
      "configurePreset": "luisa-hip-release",
      "jobs": 2
    },
    {
      "name": "classic-alembic-release",
      "configurePreset": "classic-alembic-release",
      "jobs": 2
    },
    {
      "name": "calibration-release",
      "configurePreset": "calibration-release",
      "jobs": 2
    },
    {
      "name": "autodesk-bridge-release",
      "configurePreset": "autodesk-bridge-release",
      "jobs": 2
    }
  ],
  "testPresets": [
    {
      "name": "release",
      "configurePreset": "release",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "debug",
      "configurePreset": "debug",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "native-release",
      "configurePreset": "native-release",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "cuda-release",
      "configurePreset": "cuda-release",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "hip-release",
      "configurePreset": "hip-release",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "luisa-hip-release",
      "configurePreset": "luisa-hip-release",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "classic-alembic-release",
      "configurePreset": "classic-alembic-release",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "calibration-release",
      "configurePreset": "calibration-release",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "autodesk-bridge-release",
      "configurePreset": "autodesk-bridge-release",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
